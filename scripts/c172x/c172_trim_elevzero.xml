<?xml version="1.0"?>
<runscript xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="http://jsbsim.sf.net/JSBSimScript.xsd"
    name="C172 Aileron Test">

  <use aircraft="c172x" initialize="elevator_doublet_init"/>

  <run start="0.0" end="12.0" dt="0.0083333">

    <event name="Initial Trim">
      <condition> simulation/sim-time-sec gt 0.1 </condition>
      <set name="simulation/do_simple_trim" value="1"/>
    </event>

    <event name="Force Zero Controls" continuous="true">
      <condition> simulation/sim-time-sec ge 3.0 </condition>
      <set name="fcs/elevator-cmd-norm" value="0.0"/>
      <set name="fcs/pitch-trim-cmd-norm" value="0.0"/>
    </event>

    <event name="Force Surface Direct" continuous="true">
      <condition> simulation/sim-time-sec ge 3.0 </condition>
      <set name="fcs/elevator-pos-rad" value="0.0"/> 
    </event>

  </run>
</runscript>