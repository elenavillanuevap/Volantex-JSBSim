<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="http://jsbsim.sf.net/JSBSimScript.xsl"?>
<runscript name="GBS3_trimmed3_script">
  <description>Full trim at one second with an early stabilizing trim to prevent pre-trim divergence.</description>

  <use aircraft="GBS3_trimmed3" initialize="GBS3_trimmed3_init" />

  <run start="0.0" end="5" dt="0.01">
    <property value="20.0">ic/vt-kts</property>
    <property value="1000.0">ic/h-sl-ft</property>
    <property value="9.566408">ic/alpha-deg</property>
    <property value="0.0">ic/beta-deg</property>
    <property value="0.0">ic/gamma-deg</property>
    <property value="9.566408">ic/theta-deg</property>
    <property value="0.0">ic/phi-deg</property>
    <property value="0.0">ic/psi-deg</property>
    <property value="0.0">ic/p-rad_sec</property>
    <property value="0.0">ic/q-rad_sec</property>
    <property value="0.0">ic/r-rad_sec</property>
    <property value="0.0">fcs/aileron-cmd-norm</property>
    <property value="0.0">fcs/rudder-cmd-norm</property>
    <property value="-0.001348">fcs/pitch-trim-cmd-norm</property>
    <property value="0.0">fcs/roll-trim-cmd-norm</property>
    <property value="0.0">fcs/yaw-trim-cmd-norm</property>
    <property value="1">propulsion/engine[0]/set-running</property>
    <property value="0.494078">fcs/throttle-cmd-norm</property>

    <event name="Hold seeded controls" continuous="true">
      <condition>simulation/sim-time-sec lt 1.0</condition>
      <set name="fcs/aileron-cmd-norm" value="0.0" />
      <set name="fcs/rudder-cmd-norm" value="0.0" />
      <set name="fcs/pitch-trim-cmd-norm" value="-0.001348" />
      <set name="fcs/roll-trim-cmd-norm" value="0.0" />
      <set name="fcs/yaw-trim-cmd-norm" value="0.0" />
      <set name="fcs/throttle-cmd-norm" value="0.494078" />
    </event>

    <event name="Early stabilizing trim">
      <condition>simulation/sim-time-sec ge 0.05</condition>
      <set name="simulation/do_simple_trim" value="1" />
    </event>

    <event name="Do full trim">
      <condition>simulation/sim-time-sec ge 1.0</condition>
      <set name="simulation/do_simple_trim" value="1" />
      <notify>
        <property>simulation/sim-time-sec</property>
        <property>velocities/vt-fps</property>
        <property>attitude/phi-deg</property>
        <property>attitude/theta-deg</property>
        <property>aero/alpha-deg</property>
        <property>fcs/left-aileron-pos-rad</property>
        <property>fcs/elevator-pos-rad</property>
        <property>fcs/rudder-pos-rad</property>
        <property>fcs/throttle-pos-norm</property>
        <property>accelerations/udot-ft_sec2</property>
        <property>accelerations/vdot-ft_sec2</property>
        <property>accelerations/wdot-ft_sec2</property>
        <property>accelerations/pdot-rad_sec2</property>
        <property>accelerations/qdot-rad_sec2</property>
        <property>accelerations/rdot-rad_sec2</property>
      </notify>
    </event>
  </run>
</runscript>
