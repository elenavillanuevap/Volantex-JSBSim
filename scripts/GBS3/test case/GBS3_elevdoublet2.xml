<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="http://jsbsim.sf.net/JSBSimScript.xsl"?>
<runscript name="GBS3_elevdoublet2">
  <description>Trim GBS3_trimmed2 and then apply an elevator doublet following the c172 elevator_doublet3 structure.</description>

  <use aircraft="GBS3_trimmed2" initialize="GBS3_trimmed2_init" />

  <run start="0.0" end="10.0" dt="0.01">
    <property value="20.0">ic/vt-kts</property>
    <property value="1000.0">ic/h-sl-ft</property>
    <property value="7.81">ic/alpha-deg</property>
    <property value="0.0">ic/beta-deg</property>
    <property value="0.0">ic/gamma-deg</property>
    <property value="7.81">ic/theta-deg</property>
    <property value="-0.11">ic/phi-deg</property>
    <property value="0.0">ic/psi-deg</property>
    <property value="0.0">ic/p-rad_sec</property>
    <property value="0.0">ic/q-rad_sec</property>
    <property value="0.0">ic/r-rad_sec</property>
    <property value="0.0">fcs/aileron-cmd-norm</property>
    <property value="0.0">fcs/elevator-cmd-norm</property>
    <property value="0.0">fcs/rudder-cmd-norm</property>
    <property value="0.0">fcs/pitch-trim-cmd-norm</property>
    <property value="0.0">fcs/roll-trim-cmd-norm</property>
    <property value="0.0">fcs/yaw-trim-cmd-norm</property>
    <property value="1">propulsion/engine[0]/set-running</property>
    <property value="1.0">fcs/throttle-cmd-norm</property>

    <event name="Initial trim">
      <condition>simulation/sim-time-sec ge 0.02</condition>
      <set name="simulation/do_simple_trim" value="1" />
    </event>

    <event name="Lock lateral controls" continuous="true">
      <condition>simulation/sim-time-sec ge 0.0</condition>
      <set name="fcs/aileron-cmd-norm" value="0.0" />
      <set name="fcs/rudder-cmd-norm" value="0.0" />
    </event>

    <event name="Elevator baseline pre" continuous="true">
      <condition>simulation/sim-time-sec lt 3.00</condition>
      <set name="fcs/elevator-cmd-norm" value="0.0" />
    </event>

    <event name="Pulse 1 negative" continuous="true">
      <condition>
        simulation/sim-time-sec ge 3.00
        simulation/sim-time-sec le 3.45
      </condition>
      <set name="fcs/elevator-cmd-norm">
        <function>
          <product>
            <value>-0.032</value>
            <sin>
              <quotient>
                <product>
                  <difference>
                    <property>simulation/sim-time-sec</property>
                    <value>3.00</value>
                  </difference>
                  <value>3.141592653589793</value>
                </product>
                <value>0.45</value>
              </quotient>
            </sin>
          </product>
        </function>
      </set>
    </event>

    <event name="Ramp up positive" continuous="true">
      <condition>
        simulation/sim-time-sec ge 3.45
        simulation/sim-time-sec lt 3.80
      </condition>
      <set name="fcs/elevator-cmd-norm">
        <function>
          <product>
            <value>0.034</value>
            <product>
              <value>0.5</value>
              <difference>
                <value>1.0</value>
                <cos>
                  <quotient>
                    <product>
                      <difference>
                        <property>simulation/sim-time-sec</property>
                        <value>3.45</value>
                      </difference>
                      <value>3.141592653589793</value>
                    </product>
                    <value>0.35</value>
                  </quotient>
                </cos>
              </difference>
            </product>
          </product>
        </function>
      </set>
    </event>

    <event name="Hold positive" continuous="true">
      <condition>
        simulation/sim-time-sec ge 3.80
        simulation/sim-time-sec lt 4.05
      </condition>
      <set name="fcs/elevator-cmd-norm" value="0.034" />
    </event>

    <event name="Ramp down to zero" continuous="true">
      <condition>
        simulation/sim-time-sec ge 4.05
        simulation/sim-time-sec le 4.30
      </condition>
      <set name="fcs/elevator-cmd-norm">
        <function>
          <product>
            <value>0.034</value>
            <product>
              <value>0.5</value>
              <sum>
                <value>1.0</value>
                <cos>
                  <quotient>
                    <product>
                      <difference>
                        <property>simulation/sim-time-sec</property>
                        <value>4.05</value>
                      </difference>
                      <value>3.141592653589793</value>
                    </product>
                    <value>0.25</value>
                  </quotient>
                </cos>
              </sum>
            </product>
          </product>
        </function>
      </set>
    </event>

    <event name="Pulse 3 small negative" continuous="true">
      <condition>
        simulation/sim-time-sec ge 4.30
        simulation/sim-time-sec le 4.70
      </condition>
      <set name="fcs/elevator-cmd-norm">
        <function>
          <product>
            <value>-0.016</value>
            <sin>
              <quotient>
                <product>
                  <difference>
                    <property>simulation/sim-time-sec</property>
                    <value>4.30</value>
                  </difference>
                  <value>3.141592653589793</value>
                </product>
                <value>0.40</value>
              </quotient>
            </sin>
          </product>
        </function>
      </set>
    </event>

    <event name="Elevator baseline post" continuous="true">
      <condition>simulation/sim-time-sec gt 4.70</condition>
      <set name="fcs/elevator-cmd-norm" value="0.0" />
    </event>

    <event name="Report after doublet">
      <condition>simulation/sim-time-sec ge 5.00</condition>
      <notify>
        <property>simulation/sim-time-sec</property>
        <property>fcs/elevator-cmd-norm</property>
        <property>fcs/elevator-pos-rad</property>
        <property>velocities/q-rad_sec</property>
        <property>accelerations/qdot-rad_sec2</property>
      </notify>
    </event>
  </run>
</runscript>
